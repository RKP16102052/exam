<?xml version="1.0"?>
<robot name="exam_robot">
  <!-- Определение материалов -->
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <!-- Корпус base_link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <!-- Левое колесо -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <!-- Поворот на 90° вокруг Y, чтобы цилиндр лежал горизонтально -->
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Позиция слева (y = +0.17) -->
    <origin xyz="0 0.17 0" rpy="0 0 0"/>
    <!-- Ось вращения вокруг Z (вертикальной) -->
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Правое колесо -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- Позиция справа (y = -0.17) -->
    <origin xyz="0 -0.17 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Датчик -->
  <link name="sensor_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
  </link>

  <joint name="sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_link"/>
    <!-- Позиция спереди (x = +0.2) и сверху (z = +0.08) -->
    <origin xyz="0.2 0 0.08" rpy="0 0 0"/>
  </joint>
</robot>